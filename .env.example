# --- Passmark LLM providers ---
# This project ships a Google-only override in passmark.setup.ts — every
# model slot (including assertionPrimary, which defaults to Claude) is
# pointed at a Gemini variant, so only GOOGLE_GENERATIVE_AI_API_KEY is
# required to run. Drop passmark.setup.ts if you want the default
# Claude+Gemini cross-provider consensus back, then also set ANTHROPIC_API_KEY.
GOOGLE_GENERATIVE_AI_API_KEY=AIzaxxxxxxxxxxxx
ANTHROPIC_API_KEY=

# --- Optional: Redis step cache ---
# Speeds up re-runs dramatically; first run populates, subsequent runs replay.
# Run a local redis with: docker run -d -p 6379:6379 --name passmark-redis redis:7-alpine
# REDIS_URL=redis://localhost:6379

# --- Target application URLs ---
# Self-hosted (recommended): point at your local RealWorld stack
REALWORLD_BASE_URL=http://localhost:4200
REALWORLD_API_URL=http://localhost:3000/api

# Hosted demo (fallback, shared state — use with caution):
# REALWORLD_BASE_URL=https://demo.realworld.show
# REALWORLD_API_URL=https://api.realworld.show/api
